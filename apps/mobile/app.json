{
  "expo": {
    "name": "Amara",
    "slug": "amara-wallet",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A1208"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "io.anara.wallet",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Amara uses Face ID to secure your wallet.",
        "NSMicrophoneUsageDescription": "Amara uses the microphone for voice commands."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1A1208"
      },
      "package": "io.anara.wallet",
      "permissions": [
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Secure your Amara wallet with Face ID"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#D4920A"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "scheme": "amara"
  }
}
