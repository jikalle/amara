# ─────────────────────────────────────────────────
# Anara Wallet — Environment Variables
# Copy to .env in each app that needs it
# NEVER commit .env files to git
# ─────────────────────────────────────────────────

# ── AI / Agent ────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Wallet Auth (Privy) ───────────────────────────
NEXT_PUBLIC_PRIVY_APP_ID=clxxxxxx
NEXT_PUBLIC_PRIVY_SECRET=
EXPO_PUBLIC_PRIVY_APP_ID=clxxxxxx
EXPO_PUBLIC_PRIVY_CLIENT_ID=client-xxxxxx

# ── Blockchain (Alchemy) ──────────────────────────
ALCHEMY_API_KEY=xxxxxx
NEXT_PUBLIC_ALCHEMY_API_KEY=xxxxxx
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/${ALCHEMY_API_KEY}
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/${ALCHEMY_API_KEY}
ARB_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/${ALCHEMY_API_KEY}
OP_RPC_URL=https://opt-mainnet.g.alchemy.com/v2/${ALCHEMY_API_KEY}

# ── WalletConnect ─────────────────────────────────
NEXT_PUBLIC_WALLETCONNECT_ID=xxxxxx

# ── Database (Supabase) ───────────────────────────
DATABASE_URL=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxx

# ── Cache / Queue (Upstash Redis) ─────────────────
UPSTASH_REDIS_URL=https://xxx.upstash.io
UPSTASH_REDIS_TOKEN=xxxxxx

# ── Notifications (Push Protocol) ─────────────────
PUSH_CHANNEL_ADDRESS=0x...
PUSH_CHANNEL_PRIVATE_KEY=0x...

# ── Bridge / Swap (LI.FI) ─────────────────────────
LIFI_API_KEY=xxxxxx

# ── Block Explorers ───────────────────────────────
BASESCAN_API_KEY=xxxxxx
ETHERSCAN_API_KEY=xxxxxx

# ── Deployer ──────────────────────────────────────
DEPLOYER_PRIVATE_KEY=0x...

# ── API Server ────────────────────────────────────
PORT=4000
NEXT_PUBLIC_API_URL=http://localhost:4000

# ── On-ramp (Phase 3) ─────────────────────────────
YELLOW_CARD_API_KEY=
TRANSAK_API_KEY=
MOONPAY_API_KEY=

# ── The Graph ─────────────────────────────────────
GRAPH_API_KEY=
GRAPH_BASE_SUBGRAPH_URL=https://gateway.thegraph.com/api/${GRAPH_API_KEY}/subgraphs/id/xxx
