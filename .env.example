# ─────────────────────────────────────────────────
# Amara Wallet — Environment Variables
# Copy this file to /.env at the repo root.
# The API loads /.env and will override blank app-local env files.
# NEVER commit real secrets to git.
# ─────────────────────────────────────────────────

# ── AI / Agent ────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Wallet Auth (Privy) ───────────────────────────
NEXT_PUBLIC_PRIVY_APP_ID=clxxxxxx
NEXT_PUBLIC_PRIVY_SECRET=
EXPO_PUBLIC_PRIVY_APP_ID=clxxxxxx
EXPO_PUBLIC_PRIVY_CLIENT_ID=client-xxxxxx

# ── Blockchain (Alchemy) ──────────────────────────
ALCHEMY_API_KEY=xxxxxx
NEXT_PUBLIC_ALCHEMY_API_KEY=xxxxxx
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/${ALCHEMY_API_KEY}
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/${ALCHEMY_API_KEY}
ARB_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/${ALCHEMY_API_KEY}
OP_RPC_URL=https://opt-mainnet.g.alchemy.com/v2/${ALCHEMY_API_KEY}

# ── WalletConnect ─────────────────────────────────
NEXT_PUBLIC_WALLETCONNECT_ID=xxxxxx

# ── Database (Supabase) ───────────────────────────
# Use the Supabase SESSION POOLER connection string for local dev.
# Do not use the direct db.<project-ref>.supabase.co host unless your environment
# has working IPv6 routing.
# Recommended format:
# DATABASE_URL=postgresql://postgres.<project-ref>:password@aws-0-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres.xxx:password@aws-0-us-east-1.pooler.supabase.com:5432/postgres
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxx

# ── Cache / Queue (Upstash Redis) ─────────────────
UPSTASH_REDIS_URL=https://xxx.upstash.io
UPSTASH_REDIS_TOKEN=xxxxxx

# ── Notifications (Push Protocol) ─────────────────
PUSH_CHANNEL_ADDRESS=0x...
PUSH_CHANNEL_PRIVATE_KEY=0x...

# ── Bridge / Swap (LI.FI) ─────────────────────────
LIFI_API_KEY=xxxxxx

# ── Block Explorers ───────────────────────────────
BASESCAN_API_KEY=xxxxxx
ETHERSCAN_API_KEY=xxxxxx

# ── Deployer ──────────────────────────────────────
DEPLOYER_PRIVATE_KEY=0x...

# ── API Server ────────────────────────────────────
PORT=4000
NEXT_PUBLIC_API_URL=http://localhost:4000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,exp://localhost:8081
FEATURE_SWAP_ENABLED=true
FEATURE_BRIDGE_ENABLED=true
FEATURE_SEND_ENABLED=true

# ── On-ramp (Phase 3) ─────────────────────────────
YELLOW_CARD_API_KEY=
TRANSAK_API_KEY=
TRANSAK_API_SECRET=
TRANSAK_ENVIRONMENT=STAGING
TRANSAK_REFERRER_DOMAIN=localhost:3000
MOONPAY_API_KEY=

# ── Nigeria Bank Transfer (cNGN) ──────────────────
CNGN_API_KEY=
CNGN_ENCRYPTION_KEY=
# Prefer a file path for the Ed25519 private key.
CNGN_PRIVATE_KEY_PATH=
# Optional alternative to file path:
# CNGN_PRIVATE_KEY="-----BEGIN OPENSSH PRIVATE KEY-----\n...\n-----END OPENSSH PRIVATE KEY-----"
CNGN_API_BASE_URL=https://api.cngn.co

# ── The Graph ─────────────────────────────────────
GRAPH_API_KEY=
GRAPH_BASE_SUBGRAPH_URL=https://gateway.thegraph.com/api/${GRAPH_API_KEY}/subgraphs/id/xxx
